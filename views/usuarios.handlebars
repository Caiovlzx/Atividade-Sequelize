<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Usuários</title>
</head>
<body>
    <h1>Lista de Usuários</h1>

<ul>
    {{#each usuarios}}
     <li>
        {{nome}} + {{email}} + {{idade}}
        <form action="/usuarios/deletar/{{id}}" method="POST" style="display:inline;">
             <button type="submit">Remover</button>
        </form>
    </li>
    {{/each}}
</ul>
</ul>
</body>
</html>